<?xml version="1.0" encoding="utf-8"?>
<!--
    Security hardening:
    - Cleartext HTTP is restricted to localhost only (needed for xray stats/API on 127.0.0.1)
    - User-installed CA certificates are NOT trusted for app's own HTTPS connections
      (subscription fetches, update checks, IP-check API). This prevents MitM via rogue CA.
    - Subscriptions served over plain HTTP are still loaded by xray/hev-tun, not this config.
-->
<network-security-config xmlns:tools="http://schemas.android.com/tools">
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext only to loopback for xray local API / stats -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
